# ============================================
# MEDNEAR AI - ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env file to git!

# ====== BOT CONFIGURATION ======
BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=MedNearAIBot
BOT_WEBHOOK_URL=https://your-domain.com/webhook
BOT_WEBHOOK_PORT=8443
BOT_ADMIN_IDS=123456789,987654321
BOT_DEV_ID=123456789
BOT_DEBUG=False

# ====== DATABASE (PostgreSQL) ======
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mednear_ai
DB_USER=mednear_user
DB_PASSWORD=your_secure_password_here
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_ECHO=False

# ====== REDIS ======
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your_redis_password
REDIS_URL=redis://localhost:6379/0

# ====== AI APIs ======
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7

GOOGLE_GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

GOOGLE_MAPS_API_KEY=your_google_maps_api_key

WHISPER_MODEL=whisper-1

# ====== SECURITY ======
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
ENCRYPTION_KEY=your-fernet-encryption-key

# ====== PAYMENTS ======
PAYMENT_PROVIDER_TOKEN=your_payment_provider_token
PREMIUM_1_MONTH_PRICE=25000
PREMIUM_3_MONTH_PRICE=65000
PREMIUM_12_MONTH_PRICE=200000
CURRENCY=UZS

# ====== MONITORING ======
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin_password

# ====== LOGGING ======
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10

# ====== RATE LIMITING ======
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_HOUR=200
FLOOD_PROTECTION_LIMIT=5

# ====== APP SETTINGS ======
APP_NAME=MedNear AI
APP_VERSION=1.0.0
APP_ENVIRONMENT=production
APP_TIMEZONE=Asia/Tashkent
DEFAULT_LANGUAGE=uz
SUPPORTED_LANGUAGES=uz,ru,en

# ====== ANALYTICS ======
ENABLE_ANALYTICS=True
ANALYTICS_BATCH_SIZE=100

# ====== NOTIFICATIONS ======
ENABLE_PUSH_NOTIFICATIONS=True
ENABLE_EMAIL_NOTIFICATIONS=False
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password